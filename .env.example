# The prototype works without any environment variables by using labeled sample data.

# OpenAI: reserved for GPT-5.6 extraction, analysis, simulation, and advisor routes.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Supabase: optional until persistence/authentication is connected.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Academic ingestion service: network access is opt-in and identifies its operator.
ACADEMIC_INGEST_DATABASE_URL=postgresql+psycopg://academic_ingest:academic_ingest_local@localhost:5432/academic_ingest
ACADEMIC_INGEST_CONTACT_EMAIL=
ACADEMIC_INGEST_NETWORK_ENABLED=false
ACADEMIC_INGEST_SNAPSHOT_ROOT=var/snapshots
